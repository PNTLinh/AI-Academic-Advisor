# ═══════════════════════════════════════════════════════════════════════════
# ADAPTIVE ACADEMIC ADVISOR - ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════
#
# IMPORTANT:
#   - Copy this file to .env and fill in your values
#   - Leave ANTHROPIC_API_KEY empty to run with mock data
#   - DATABASE_URL should point to PostgreSQL (Neon/Supabase) for Railway
#   - NEXT_PUBLIC_* variables are exposed to frontend (do NOT put secrets)
#

# ─── ANTHROPIC LLM CONFIGURATION ──────────────────────────────────────────
# Optional: Anthropic API Key for real AI chat responses
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Alternative: OpenAI API Key (fallback)
OPENAI_API_KEY=

# ─── DATABASE CONFIGURATION ──────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, RDS, etc.)
# Format: postgresql://username:password@host:5432/database?sslmode=require
# 
# For Neon (https://neon.tech):
# 1. Create a database project
# 2. Copy the "Connection string" from Neon dashboard
# 3. Paste it here as DATABASE_URL
# 
# Example: postgresql://neondb_owner:xxxx@ep-xxx.neon.tech/neondb?sslmode=require
#
DATABASE_URL=

# ─── SERVER CONFIGURATION ─────────────────────────────────────────────────
# CORS Origins - Comma-separated list of allowed frontend URLs
ALLOWED_ORIGINS=*

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Data directory (PDFs, uploads, etc.)
# Leave empty to use ./data (local) or /app/data (Docker)
# DATA_DIR=

# ─── FRONTEND CONFIGURATION ──────────────────────────────────────────────
# Backend API URL for frontend (public - visible in browser)
# Local dev: http://localhost:8000/api
# Railway: https://your-backend-service.railway.app/api
# 
NEXT_PUBLIC_API_URL=http://localhost:8000/api

# ─── AI LOGGING (OPTIONAL) ────────────────────────────────────────────
# For tracking AI tool usage (can be empty)
AI_LOG_SERVER=
AI_LOG_API_KEY=
AI_LOG_DIR=.ai-log

# ═══════════════════════════════════════════════════════════════════════════
# DEPLOYMENT EXAMPLES
# ═══════════════════════════════════════════════════════════════════════════
#
# Local Development (SQLite, mock AI):
#   $ cp .env.example .env
#   $ docker-compose up
#
# Railway Deployment (PostgreSQL + Neon):
#   1. Set DATABASE_URL in Railway environment variables
#   2. Set NEXT_PUBLIC_API_URL = https://your-backend.railway.app/api
#   3. Deploy: git push origin main (Railway auto-deploys)
#
# ═══════════════════════════════════════════════════════════════════════════
