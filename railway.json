{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile",
    "buildCommand": "docker build -t app:latest ."
  },
  "deploy": {
    "numReplicas": 1,
    "startCommand": "sh -c \"uvicorn src.server.main:app --host 0.0.0.0 --port $PORT\""
  },
  "variables": {
    "PORT": "8000"
  }
}
